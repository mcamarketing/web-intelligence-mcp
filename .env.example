# Web Intelligence MCP Server - Environment Variables

# Required API Keys

# SerpAPI - Web search (https://serpapi.com)
# Free tier: 100 searches/month
SERPAPI_KEY=your_serpapi_key_here

# Jina AI - Web scraping (https://jina.ai/reader)
# Free tier: 1M tokens/day
JINA_AI_KEY=your_jina_key_here

# Google Places API - Lead generation (https://cloud.google.com)
# Free tier: $200 credit/month
GOOGLE_PLACES_API_KEY=your_google_places_key_here

# Clearbit - Company intelligence (https://clearbit.com)
# Free tier: 250 requests/month
CLEARBIT_API_KEY=your_clearbit_key_here

# Optional - Enhanced company data

# BuiltWith - Tech stack detection (https://builtwith.com)
BUILTWITH_API_KEY=your_builtwith_key_here

# Hunter.io - Email finding (https://hunter.io)
HUNTER_API_KEY=your_hunter_key_here

# Apify Configuration
APIFY_LOG_LEVEL=INFO
APIFY_WEB_SERVER_PORT=3000

# MCP Transport (stdio for local testing, sse for production)
MCP_TRANSPORT=sse
